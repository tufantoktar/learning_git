# Copy to .env and adjust locally. Never commit real secrets.

# Fund selection.
# Selected mode: comma-separated TEFAS fund codes.
TEFAS_FUND_CODES=AFT,MAC,TCD

# All-funds mode: set true, or set TEFAS_FUND_CODES=ALL.
TEFAS_ANALYZE_ALL_FUNDS=false

# Optional safety limit for smoke tests. Leave empty for all discovered funds.
TEFAS_MAX_FUNDS=

# Store raw TEFAS payloads in SQLite. Set false in broad all-funds scans if needed.
TEFAS_SAVE_RAW_PAYLOAD=true

# Classify fund categories and use category-aware deterministic scoring.
TEFAS_ENABLE_CATEGORY_SCORING=true

# Approximate money inflow/outflow from TEFAS fund size, price, and investor count fields.
TEFAS_ENABLE_MONEY_FLOW_ANALYSIS=true

# Generate deterministic analytical tags such as OVERHEATED and HIGH_DRAWDOWN.
TEFAS_ENABLE_ANALYTICAL_TAGS=true

# Report display language: tr or en.
TEFAS_REPORT_LANGUAGE=tr

# Optional config file path. CLI --config takes precedence.
TEFAS_CONFIG_FILE=config/config.example.json

# SQLite URL. Relative paths resolve from the working directory.
TEFAS_DATABASE_URL=sqlite:///data/tefas_analysis.sqlite3
TEFAS_REPORT_OUTPUT_DIR=reports/output
TEFAS_OPERATIONAL_LOG_PATH=logs/pipeline_runs.jsonl

# Collector behavior.
TEFAS_BASE_URL=https://fundturkey.com.tr/api/DB/BindHistoryInfo
TEFAS_ALLOCATION_URL=https://fundturkey.com.tr/api/DB/BindHistoryAllocation
TEFAS_ORIGIN=https://fundturkey.com.tr
TEFAS_REFERER=https://fundturkey.com.tr/TarihselVeriler.aspx
TEFAS_LOOKBACK_DAYS=120
TEFAS_TIMEOUT_SECONDS=20
TEFAS_MAX_RETRIES=3

# Optional scheduler.
TEFAS_SCHEDULE_ENABLED=false
TEFAS_SCHEDULE_TIME=18:30
TEFAS_SCHEDULE_TIMEZONE=Europe/Istanbul

# Optional Telegram notifications.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
